# ─────────────────────────────────────────────────────────────────────────────
# Notio — Local Development  (cp .env.example .env)
#
# Admin Panel:  http://localhost       (admin@notioedu.com / PLATFORM_ADMIN_PASSWORD)
# Landing:      http://localhost:3000
# Backend API:  http://localhost:5001
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=edulink
POSTGRES_USER=edulink_user
POSTGRES_PASSWORD=edulink_pass

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-key-at-least-32-characters-long!!
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# ── Platform Admin ────────────────────────────────────────────────────────────
PLATFORM_ADMIN_PASSWORD=Admin123!

# ── Cloudinary (medya yükleme — gerçek değerleri cloudinary.com'dan al) ───────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_API_KEY=ai-dev-key

# ── Firebase (push bildirim, lokal için boş bırakılabilir) ────────────────────
FIREBASE_SERVER_KEY=dev

# ── SMTP (e-posta, opsiyonel) ─────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_FROM=noreply@notioedu.com

# ── ASP.NET ───────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ── Mobil Expo ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:5000/api
EXPO_PUBLIC_SIGNALR_URL=http://localhost:5000/hubs/chat
